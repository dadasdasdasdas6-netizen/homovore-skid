package homovore.module;

import net.minecraft.client.Minecraft;
import net.minecraft.world.item.Items;
import net.minecraft.world.item.ItemStack;
import net.minecraft.world.entity.EquipmentSlot;
import net.minecraft.world.item.ArmorItem;
import net.minecraft.world.inventory.ClickType;
import homovore.event.EventTarget;
import homovore.event.impl.EventTick;
import homovore.module.Category;
import homovore.module.Module;

public class ChestSwap extends Module {

    private int timer = 0;

    public ChestSwap() {
        super("ChestSwap", "Silently swaps between elytra and chestplate", Category.PLAYER);
    }

    @EventTarget
    public void onTick(EventTick event) {
        if (!isEnabled()) return;

        // Only run every 2 ticks to avoid spam
        timer++;
        if (timer < 2) return;
        timer = 0;

        var mc = Minecraft.getInstance();
        var player = mc.player;
        if (player == null) return;

        // Container slots: 0-8 hotbar, 9-35 main, 36 boots, 37 leggings, 38 chestplate, 39 helmet, 40 offhand
        int chestSlot = 38;

        ItemStack currentChest = player.getItemBySlot(EquipmentSlot.CHEST);
        boolean wearingElytra = currentChest.is(Items.ELYTRA);
        boolean flying = player.isFallFlying();

        if (flying && !wearingElytra) {
            // Need elytra – find it in inventory and swap to chest slot
            for (int i = 0; i < 36; i++) {
                ItemStack stack = player.getInventory().getItem(i);
                if (stack.is(Items.ELYTRA)) {
                    silentSwap(i, chestSlot);
                    break;
                }
            }
        } else if (!flying && wearingElytra && player.onGround()) {
            // Need chestplate – find best one and swap
            int bestSlot = -1;
            float bestDefense = -1;
            for (int i = 0; i < 36; i++) {
                ItemStack stack = player.getInventory().getItem(i);
                if (stack.getItem() instanceof ArmorItem armor && armor.getEquipmentSlot() == EquipmentSlot.CHEST) {
                    float def = armor.getDefense();
                    if (def > bestDefense) {
                        bestDefense = def;
                        bestSlot = i;
                    }
                }
            }
            if (bestSlot != -1) {
                silentSwap(bestSlot, chestSlot);
            }
        }
    }

    private void silentSwap(int sourceSlot, int targetSlot) {
        var mc = Minecraft.getInstance();
        var player = mc.player;
        if (player == null) return;

        // Use the player's inventory container (always open)
        int containerId = player.containerMenu.containerId;
        mc.gameMode.handleInventoryMouseClick(containerId, sourceSlot, targetSlot, ClickType.SWAP, player);
    }
}
